# Ignore bundler config.
/.bundle

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (Active Storage, Kamal, etc.).
/storage/*
!/storage/.keep

# Ignore master key for decrypting credentials and more.
/config/master.key
/config/credentials/*.key

# Ignore node_modules.
/node_modules

# Ignore macOS files.
.DS_Store

# Ignore asset builds (regenerated by tailwindcss-rails).
/app/assets/builds/*
!/app/assets/builds/.keep

# Ignore IDE/editor files.
.idea/
.vscode/
*.swp
*.swo
*~

# Ignore bootsnap cache.
/tmp/cache/bootsnap

# Ignore .specstory statistics.
.specstory/
